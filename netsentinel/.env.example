# NetSentinel Environment Variables
# Copy to .env and fill in your values

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/netsentinel

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka (optional)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=network-packets

# Capture
CAPTURE_INTERFACE=eth0
BPF_FILTER=ip

# AI Model paths
AE_MODEL_PATH=data/models/autoencoder.pt
IF_MODEL_PATH=data/models/isolation_forest.pkl

# Topology
ARP_SCAN_NETWORKS=192.168.1.0/24

# Security (change in production)
API_KEY=dev-api-key-change-me
SECRET_KEY=dev-secret-key-change-me